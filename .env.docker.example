# Copy this file to `.env.docker` and fill every required secret before deploy.
# Start with: docker compose --env-file .env.docker up -d --build

APP_NAME=TPSS

# Required: generate a unique key once and keep it stable.
# Example: php artisan key:generate --show
APP_KEY=

# Public URL that end users will access.
APP_URL=http://localhost:8080
APP_PORT=8080
TRUSTED_PROXIES=*

# Locale / cookies
APP_LOCALE=th
APP_FALLBACK_LOCALE=th
# Set to true when the public URL is HTTPS.
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Logging
LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_LEVEL=info

# Database
DB_DATABASE=tpss
DB_USERNAME=tpss
DB_PASSWORD=tpss_secret
DB_ROOT_PASSWORD=root_secret

# First boot only: set true if you intentionally want demo seed data.
# Change back to false after initial setup.
DB_SEED=false

# Async conflict read models depend on queue + scheduler services.
CONFLICT_ASYNC_READS=true
