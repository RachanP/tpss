# คัดลอกเป็น .env.docker แล้วแก้ค่าก่อน deploy
# docker compose --env-file .env.docker up -d --build

# APP_KEY คงที่ (ถ้าเปลี่ยน session/encrypted data เดิมจะใช้ไม่ได้)
APP_KEY=base64:7TbxWiguATo7zcA5we5AZ/C+VuvXanVZS+nPwR6TCMU=

# URL ที่ลูกค้าเข้าทดสอบ — ใส่ domain หรือ http://<server-ip>:<port>
APP_URL=http://localhost:8080

# พอร์ตบน host (ถ้า server เปิด 80 ตรง ให้ตั้ง 80)
APP_PORT=8080

# ฐานข้อมูล (เปลี่ยน password ก่อน deploy จริง)
DB_DATABASE=tpss
DB_USERNAME=tpss
DB_PASSWORD=tpss_secret
DB_ROOT_PASSWORD=root_secret

# ตั้ง true เฉพาะ "ครั้งแรก" เพื่อ seed ข้อมูล demo — รอบถัดไปตั้ง false
DB_SEED=true
